{
    "name": "liza/qubel",
    "description": "Pizza store library",
    "type": "library",
    "autoload": {
        "psr-4": {
            "Liza\\Qubell\\": "src/"
        }
    },
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "authors": [
        {
            "name": "Milkis"
        }
    ],
    "scripts": {
        "analyse": "phpstan analyse src --level=max",
        "check-style": "phpcs --standard=PSR12 src",
        "fix-style": "phpcbf --standard=PSR12 src"
    }
}
